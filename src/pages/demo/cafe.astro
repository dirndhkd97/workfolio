---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="온도 ONDO | 따뜻한 한 잔의 여유" description="온도(ONDO) - 정성을 담은 커피와 디저트, 따뜻한 공간에서 만나는 작은 행복">

<style is:global>
  body {
    background-color: #F5F0EB !important;
    color: #2C1810 !important;
  }
  ::selection {
    background-color: #D2691E !important;
    color: #fff !important;
  }
  html {
    scroll-behavior: smooth;
  }
</style>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 50%, #D2691E15 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, #8B451312 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, #D2691E08 0%, transparent 50%),
      linear-gradient(180deg, #2C1810 0%, #3D2317 40%, #4A2C1A 70%, #5C3620 100%);
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23F5F0EB' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.5;
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    border: 1px solid #F5F0EB30;
    border-radius: 9999px;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #D2B48C;
    margin-bottom: 2rem;
    backdrop-filter: blur(4px);
    background: #F5F0EB08;
  }
  .hero h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 200;
    color: #F5F0EB;
    letter-spacing: 0.05em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .hero h1 span {
    display: block;
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    color: #D2B48C;
    margin-top: 0.75rem;
  }
  .hero-sub {
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    color: #D2B48CAA;
    margin-top: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
  }
  .hero-divider {
    width: 40px;
    height: 1px;
    background: #D2B48C60;
    margin: 2rem auto;
  }
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: #D2B48C80;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: color 0.3s;
  }
  .hero-scroll:hover { color: #D2B48C; }
  .hero-scroll::after {
    content: '';
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, #D2B48C80, transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); }
  }

  /* Shared section */
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 72rem; margin: 0 auto; }
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #8B4513;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 300;
    color: #2C1810;
    letter-spacing: 0.02em;
    line-height: 1.3;
  }
  .section-desc {
    color: #6B4C3B;
    font-size: 1rem;
    line-height: 1.8;
    font-weight: 300;
    max-width: 36rem;
  }
  .thin-line {
    width: 40px;
    height: 1px;
    background: #8B451340;
    margin: 1.5rem 0;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-visual {
    aspect-ratio: 4/5;
    border-radius: 1rem;
    overflow: hidden;
    position: relative;
  }
  .about-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .stat-card {
    text-align: center;
    padding: 1.25rem;
    border-radius: 0.75rem;
    background: #2C181008;
    border: 1px solid #2C181010;
    transition: all 0.3s;
  }
  .stat-card:hover {
    background: #2C181012;
    transform: translateY(-2px);
  }
  .stat-number {
    font-size: 1.5rem;
    font-weight: 300;
    color: #8B4513;
    margin-bottom: 0.25rem;
  }
  .stat-text {
    font-size: 0.75rem;
    color: #6B4C3B;
    letter-spacing: 0.05em;
  }

  /* Menu */
  .menu-section {
    background:
      radial-gradient(ellipse at 20% 0%, #D2691E06 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, #8B451306 0%, transparent 50%),
      #EDE6DD;
  }
  .menu-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .menu-tab {
    padding: 0.625rem 1.5rem;
    border-radius: 9999px;
    border: 1px solid #2C181020;
    background: transparent;
    color: #6B4C3B;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s;
    font-family: var(--font-sans);
    letter-spacing: 0.03em;
  }
  .menu-tab:hover, .menu-tab.active {
    background: #2C1810;
    color: #F5F0EB;
    border-color: #2C1810;
  }
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1px;
    background: #2C181010;
    border-radius: 1rem;
    overflow: hidden;
  }
  .menu-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1.5rem 1.75rem;
    background: #F5F0EB;
    transition: all 0.3s;
    gap: 1rem;
  }
  .menu-item:hover {
    background: #FAF7F3;
  }
  .menu-name {
    font-size: 1rem;
    font-weight: 400;
    color: #2C1810;
    margin-bottom: 0.25rem;
  }
  .menu-desc {
    font-size: 0.8rem;
    color: #8B7355;
    font-weight: 300;
    line-height: 1.5;
  }
  .menu-price {
    font-size: 0.95rem;
    font-weight: 400;
    color: #8B4513;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .menu-badge {
    display: inline-block;
    font-size: 0.6rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: #D2691E15;
    color: #D2691E;
    letter-spacing: 0.05em;
    margin-left: 0.5rem;
    vertical-align: middle;
    font-weight: 500;
  }

  /* Gallery */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 14rem);
    gap: 0.75rem;
  }
  .gallery-cell {
    border-radius: 0.75rem;
    overflow: hidden;
    position: relative;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: pointer;
  }
  .gallery-cell:hover {
    transform: scale(1.02);
    box-shadow: 0 20px 40px -10px rgba(44, 24, 16, 0.15);
  }
  .gallery-cell:nth-child(1) { grid-column: span 2; }
  .gallery-cell:nth-child(6) { grid-column: span 2; }
  .gallery-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .gallery-cell:hover img {
    transform: scale(1.08);
  }
  .gallery-cell::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(44, 24, 16, 0.25), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .gallery-cell:hover::after {
    opacity: 1;
  }
  .gallery-label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    color: #F5F0EB;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    font-weight: 300;
    z-index: 1;
    opacity: 0;
    transform: translateY(4px);
    transition: all 0.3s;
  }
  .gallery-cell:hover .gallery-label {
    opacity: 1;
    transform: translateY(0);
  }

  /* Location */
  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .map-container {
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 4/3;
    position: relative;
  }
  .map-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .map-directions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    background: #2C1810;
    color: #F5F0EB;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.3s;
  }
  .map-directions:hover {
    background: #8B4513;
    transform: translateY(-1px);
  }
  .map-directions svg {
    width: 16px;
    height: 16px;
  }
  .info-block { margin-bottom: 2rem; }
  .info-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #8B4513;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }
  .info-text {
    color: #4A3728;
    font-size: 0.95rem;
    line-height: 1.9;
    font-weight: 300;
  }
  .info-hours {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 1.5rem;
  }
  .info-hours dt {
    color: #6B4C3B;
    font-size: 0.85rem;
    font-weight: 400;
  }
  .info-hours dd {
    color: #4A3728;
    font-size: 0.85rem;
    font-weight: 300;
  }

  /* Footer */
  .footer {
    background: #2C1810;
    color: #D2B48C;
    padding: 3rem 1.5rem 2rem;
    text-align: center;
  }
  .footer-logo {
    font-size: 1.5rem;
    font-weight: 200;
    letter-spacing: 0.1em;
    color: #F5F0EB;
    margin-bottom: 0.5rem;
  }
  .footer-sub {
    font-size: 0.8rem;
    color: #D2B48C80;
    margin-bottom: 2rem;
    letter-spacing: 0.1em;
  }
  .footer-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-links a {
    color: #D2B48C80;
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }
  .footer-links a:hover { color: #F5F0EB; }
  .footer-divider {
    width: 60px;
    height: 1px;
    background: #D2B48C20;
    margin: 0 auto 1.5rem;
  }
  .footer-copy {
    font-size: 0.7rem;
    color: #D2B48C50;
    letter-spacing: 0.05em;
  }
  .powered-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1.25rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid #D2B48C20;
    font-size: 0.65rem;
    color: #D2B48C60;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.3s;
  }
  .powered-badge:hover {
    color: #D2B48C;
    border-color: #D2B48C40;
    background: #D2B48C08;
  }

  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.4s;
    background: transparent;
  }
  .nav.scrolled {
    background: #2C1810F0;
    backdrop-filter: blur(12px);
    padding: 0.75rem 2rem;
    box-shadow: 0 1px 0 #D2B48C10;
  }
  .nav-logo {
    font-size: 1.125rem;
    font-weight: 300;
    color: #F5F0EB;
    letter-spacing: 0.1em;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    color: #D2B48CAA;
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    transition: color 0.3s;
    font-weight: 300;
  }
  .nav-links a:hover { color: #F5F0EB; }

  /* Mobile nav toggle */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    width: 24px;
    height: 18px;
    position: relative;
    cursor: pointer;
    flex-shrink: 0;
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: #F5F0EB;
    position: absolute;
    left: 0;
    transition: all 0.3s;
  }
  .nav-toggle span:nth-child(1) { top: 0; }
  .nav-toggle span:nth-child(2) { top: 50%; transform: translateY(-50%); }
  .nav-toggle span:nth-child(3) { bottom: 0; }

  /* CTA button */
  .cta-btn {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    border: 1px solid #D2B48C60;
    color: #F5F0EB;
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    border-radius: 9999px;
    transition: all 0.4s;
    margin-top: 2.5rem;
  }
  .cta-btn:hover {
    background: #F5F0EB;
    color: #2C1810;
    border-color: #F5F0EB;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .about-grid, .location-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .about-visual { max-height: 24rem; }
  }
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-toggle { display: block; }
    .nav-links.open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #2C1810F5;
      backdrop-filter: blur(12px);
      padding: 1.5rem 2rem;
      gap: 1.25rem;
    }
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, 10rem);
    }
    .gallery-cell:nth-child(1) { grid-column: span 2; }
    .gallery-cell:nth-child(6) { grid-column: span 2; }
    .section { padding: 3.5rem 1.25rem; }
    .menu-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Navigation -->
<nav class="nav" id="navbar">
  <a href="#hero" class="nav-logo">온도</a>
  <button class="nav-toggle" id="navToggle" aria-label="메뉴 열기">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <ul class="nav-links" id="navLinks">
    <li><a href="#about">소개</a></li>
    <li><a href="#menu">메뉴</a></li>
    <li><a href="#gallery">공간</a></li>
    <li><a href="#location">오시는 길</a></li>
  </ul>
</nav>

<!-- Hero -->
<section class="hero" id="hero">
  <div class="hero-content">
    <div class="hero-badge">Since 2019</div>
    <h1>
      온도
      <span>O N D O</span>
    </h1>
    <div class="hero-divider"></div>
    <p class="hero-sub">따뜻한 한 잔이 만드는, 작은 행복</p>
    <a href="#menu" class="cta-btn">메뉴 보기</a>
  </div>
  <a href="#about" class="hero-scroll">Scroll</a>
</section>

<!-- About -->
<section class="section" id="about">
  <div class="section-inner">
    <div class="about-grid">
      <div class="about-visual">
        <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=600&h=750&fit=crop" alt="카페 바리스타" loading="lazy" />
      </div>
      <div>
        <p class="section-label">About Us</p>
        <h2 class="section-title">한 잔의 커피에<br/>정성을 담습니다</h2>
        <div class="thin-line"></div>
        <p class="section-desc">
          온도는 '적정한 온도'에서 영감을 받은 이름입니다.
          최적의 온도로 추출한 커피 한 잔, 갓 구운 디저트의 따스함,
          그리고 편안한 공간이 전하는 온기까지.
          <br/><br/>
          우리는 단순한 카페가 아닌, 일상 속 작은 쉼표가 되고 싶습니다.
          바쁜 하루 중 잠시 멈춰 서서, 나만의 시간을 가져보세요.
        </p>
        <div class="about-stats">
          <div class="stat-card">
            <div class="stat-number">7</div>
            <div class="stat-text">운영 햇수</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">12+</div>
            <div class="stat-text">원두 종류</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">4.9</div>
            <div class="stat-text">평점</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Menu -->
<section class="section menu-section" id="menu">
  <div class="section-inner">
    <p class="section-label">Menu</p>
    <h2 class="section-title">정성을 담은 메뉴</h2>
    <div class="thin-line"></div>
    <p class="section-desc" style="margin-bottom: 2.5rem;">
      매일 아침 로스팅한 신선한 원두와 엄선한 재료로 준비합니다.
    </p>

    <div class="menu-tabs">
      <button class="menu-tab active" data-tab="coffee">커피</button>
      <button class="menu-tab" data-tab="non-coffee">논커피</button>
      <button class="menu-tab" data-tab="dessert">디저트</button>
    </div>

    <!-- Coffee Menu -->
    <div class="menu-grid" id="tab-coffee">
      <div class="menu-item">
        <div>
          <div class="menu-name">온도 시그니처 블렌드 <span class="menu-badge">BEST</span></div>
          <div class="menu-desc">다크 초콜릿과 견과류의 깊은 풍미</div>
        </div>
        <div class="menu-price">5,500</div>
      </div>
      <div class="menu-item">
        <div>
          <div class="menu-name">에티오피아 예가체프</div>
          <div class="menu-desc">플로럴 향과 밝은 산미, 싱글 오리진</div>
        </div>
        <div class="menu-price">6,000</div>
      </div>
      <div class="menu-item">
        <div>
          <div class="menu-name">카페 라떼</div>
          <div class="menu-desc">부드러운 우유 거품과 에스프레소의 조화</div>
        </div>
        <div class="menu-price">5,500</div>
      </div>
      <div class="menu-item">
        <div>
          <div class="menu-name">바닐라 플랫 화이트</div>
          <div class="menu-desc">마다가스카르 바닐라빈, 벨벳 밀크폼</div>
        </div>
        <div class="menu-price">6,500</div>
      </div>
      <div class="menu-item">
        <div>
          <div class="menu-name">콜드브루</div>
          <div class="menu-desc">24시간 저온 추출, 깔끔한 뒷맛</div>
        </div>
        <div class="menu-price">5,000</div>
      </div>
      <div class="menu-item">
