---
import Layout from '../layouts/Layout.astro';
---

<Layout title="결제하기 | Workfolio">
  <header class="fixed top-0 left-0 right-0 z-50 bg-primary/80 backdrop-blur-xl border-b border-surface-border">
    <nav class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight">
        <span class="text-accent-light">W</span><span class="text-white">orkfolio</span>
      </a>
      <a href="/#pricing" class="text-sm text-muted hover:text-white transition-colors">요금 안내</a>
    </nav>
  </header>

  <main class="pt-32 pb-24">
    <div class="mx-auto max-w-2xl px-6">
      <!-- 로딩 -->
      <div id="loading" class="text-center py-16">
        <div class="w-12 h-12 border-4 border-accent/30 border-t-accent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-muted">확인 중...</p>
      </div>

      <div id="checkout-content" class="hidden">
        <span class="text-sm font-medium text-accent-light tracking-wider font-mono">// checkout</span>
        <h1 class="mt-4 text-3xl font-bold text-white mb-8">구독 결제</h1>

        <!-- 플랜 정보 -->
        <div class="rounded-xl border border-surface-border bg-surface-light/20 p-6 mb-8">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-accent-light font-mono mb-1" id="plan-category"></p>
              <h2 class="text-xl font-bold text-white" id="plan-name"></h2>
              <p class="text-sm text-muted mt-1" id="plan-description"></p>
            </div>
            <div class="text-right">
              <p class="text-3xl font-extrabold text-white"><span id="plan-price"></span><span class="text-lg">만원</span></p>
              <p class="text-sm text-muted">/월 (정기결제)</p>
            </div>
          </div>
        </div>

        <!-- 주문자 정보 (DB에서 자동 채움) -->
        <div class="rounded-xl border border-surface-border bg-surface-light/20 p-6 mb-8">
          <h3 class="text-lg font-bold text-white mb-4">주문자 정보</h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-muted">이름</span>
              <span class="text-white" id="customer-name"></span>
            </div>
            <div class="flex justify-between">
              <span class="text-muted">이메일</span>
              <span class="text-white" id="customer-email"></span>
            </div>
            <div class="flex justify-between" id="company-row">
              <span class="text-muted">회사</span>
              <span class="text-white" id="customer-company"></span>
            </div>
            <div class="flex justify-between" id="phone-row">
              <span class="text-muted">연락처</span>
              <span class="text-white" id="customer-phone"></span>
            </div>
          </div>
        </div>

        <!-- 약관 동의 -->
        <div class="rounded-xl border border-surface-border bg-surface-light/20 p-6 mb-8">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="agree-terms" class="mt-1 accent-indigo-500" />
            <span class="text-sm text-muted">
              <a href="/terms" target="_blank" class="text-accent-light hover:underline">이용약관</a> 및
              <a href="/privacy" target="_blank" class="text-accent-light hover:underline">개인정보처리방침</a>에 동의하며,
              정기결제(빌링) 등록에 동의합니다.
            </span>
          </label>
        </div>

        <button id="btn-pay" disabled
          class="w-full rounded-xl bg-accent py-4 text-white font-bold text-lg transition-all hover:bg-accent-light disabled:opacity-40 disabled:cursor-not-allowed">
          카드 등록 및 결제하기
        </button>

        <p class="mt-4 text-center text-xs text-muted/50">
          결제는 토스페이먼츠를 통해 안전하게 처리됩니다.
        </p>

        <p id="error-msg" class="mt-4 text-center text-sm text-red-400 hidden"></p>
      </div>
    </div>
  </main>

  <footer class="border-t border-surface-border">
    <div class="mx-auto max-w-7xl px-6 py-8 space-y-4 text-xs text-muted/60">
      <div class="space-y-1">
        <p>상호명: 빌드원(BuildWon) | 대표: 노희원 | 사업자등록번호: 640-21-02096</p>
        <p>통신판매업 신고번호: 2026-서울송파-0623 | 전화: 010-9255-6115 | 이메일: contact@workfolio.life</p>
        <p>주소: 서울특별시 송파구 송이로2길 20(송파동)</p>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-muted">
        <p>&copy; {new Date().getFullYear()} buildWon. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="/privacy" class="hover:text-white transition-colors">개인정보처리방침</a>
          <a href="/terms" class="hover:text-white transition-colors">이용약관</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<script src="https://js.tosspayments.com/v2/standard" is:inline></script>

<script is:inline>
  const PLANS = {
    'web-lite':        { category: '웹 관리', name: 'Lite', price: '3', amount: 30000, description: '기본 유지만 필요한 분' },
    'web-standard':    { category: '웹 관리', name: 'Standard', price: '7', amount: 70000, description: '가장 인기 있는 플랜' },
    'web-pro':         { category: '웹 관리', name: 'Pro', price: '15', amount: 150000, description: '적극적인 관리가 필요한 분' },
    'app-basic':       { category: '앱 관리', name: 'App Basic', price: '10', amount: 100000, description: '최소한의 앱 유지 관리' },
    'app-standard':    { category: '앱 관리', name: 'App Standard', price: '20', amount: 200000, description: '안정적인 앱 운영' },
    'app-pro':         { category: '앱 관리', name: 'App Pro', price: '35', amount: 350000, description: '풀 매니지드 앱 관리' },
    'bundle-standard': { category: '웹+앱 번들', name: 'Bundle Standard', price: '22', amount: 220000, description: '웹 Standard + App Standard' },
    'bundle-pro':      { category: '웹+앱 번들', name: 'Bundle Pro', price: '40', amount: 400000, description: '웹 Pro + App Pro' },
  };

  const urlParams = new URLSearchParams(window.location.search);
  const planId = urlParams.get('plan');
  const plan = PLANS[planId];

  if (!plan) {
    window.location.href = '/#pricing';
  }

  // 로그인 확인 + 회원 정보 로드
  let userData = null;

  (async () => {
    try {
      const res = await fetch('/api/auth/me');
      if (!res.ok) {
        window.location.href = '/auth?plan=' + planId;
        return;
      }
      userData = await res.json();
    } catch {
      window.location.href = '/auth?plan=' + planId;
      return;
    }

    // 플랜 정보 표시
    document.getElementById('plan-category').textContent = plan.category;
    document.getElementById('plan-name').textContent = plan.name;
    document.getElementById('plan-price').textContent = plan.price;
    document.getElementById('plan-description').textContent = plan.description;

    // 주문자 정보 표시
    const c = userData.customer || {};
    document.getElementById('customer-name').textContent = c.name || '-';
    document.getElementById('customer-email').textContent = userData.email;
    if (c.company) {
      document.getElementById('customer-company').textContent = c.company;
    } else {
      document.getElementById('company-row').classList.add('hidden');
    }
    if (c.phone) {
      document.getElementById('customer-phone').textContent = c.phone;
    } else {
      document.getElementById('phone-row').classList.add('hidden');
    }

    document.getElementById('loading').classList.add('hidden');
    document.getElementById('checkout-content').classList.remove('hidden');
  })();

  // 약관 동의
  const agreeCheckbox = document.getElementById('agree-terms');
  const payBtn = document.getElementById('btn-pay');
  agreeCheckbox.addEventListener('change', () => {
    payBtn.disabled = !agreeCheckbox.checked;
  });

  // 결제
  const clientKey = 'test_ck_DnyRpQWGrNWKoa97aQoL8Kwv1M9E';

  payBtn.addEventListener('click', async () => {
    const errorMsg = document.getElementById('error-msg');
    errorMsg.classList.add('hidden');
    payBtn.disabled = true;
    payBtn.textContent = '처리 중...';

    try {
      const c = userData.customer || {};
      // 이메일 기반 고정 customerKey
      const emailHash = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(userData.email));
      const hashHex = Array.from(new Uint8Array(emailHash)).map(b => b.toString(16).padStart(2, '0')).join('');
      const customerKey = 'cust_' + hashHex.slice(0, 20);

      const tossPayments = TossPayments(clientKey);
      const payment = tossPayments.payment({ customerKey });

      await payment.requestBillingAuth({
        method: 'CARD',
        successUrl: window.location.origin + '/checkout/success?plan=' + planId,
        failUrl: window.location.origin + '/checkout/fail',
        customerEmail: userData.email,
        customerName: c.name || '',
      });
    } catch (err) {
      errorMsg.textContent = err.message || '결제 요청 중 오류가 발생했습니다.';
      errorMsg.classList.remove('hidden');
      payBtn.disabled = false;
      payBtn.textContent = '카드 등록 및 결제하기';
    }
  });
</script>
