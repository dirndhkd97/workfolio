  {
    name: 'Bundle Standard',
    price: '22',
    originalPrice: '27',
    description: '웹 Standard + App Standard',
    discount: '19%',
    webFeatures: ['콘텐츠 수정 월 4회', '장애 대응 24시간', 'SEO 기본 관리', '소규모 기능 변경'],
    appFeatures: ['버그 수정 월 4건', '장애 대응 24시간', '크래시 모니터링', 'Push 알림 관리'],
    highlighted: true,
  },
  {
    name: 'Bundle Pro',
    price: '40',
    originalPrice: '50',
    description: '웹 Pro + App Pro',
    discount: '20%',
    webFeatures: ['콘텐츠 수정 월 8회', '장애 대응 4시간', 'SEO 관리 & 최적화', '중규모 기능 추가/변경'],
    appFeatures: ['버그 수정 무제한', '장애 대응 4시간', '크래시 모니터링 & 리포트', '중규모 기능 추가/변경'],
