    features: [
      { text: '서버 & 인프라 관리', included: true },
      { text: '스토어 관리 (iOS/Android)', included: true },
      { text: 'OS 업데이트 대응', included: true },
      { text: '버그 수정 월 4건', included: true },
      { text: '장애 대응 (24시간)', included: true },
      { text: '크래시 모니터링', included: true },
