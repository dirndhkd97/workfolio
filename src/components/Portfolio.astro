---
const projects = [
  {
    title: 'WODMate',
    subtitle: '크로스핏 운동 기록 앱',
    category: '모바일 앱',
    image: 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&h=450&fit=crop',
    overlay: 'from-teal-900/80 to-teal-800/40',
    description: '크로스핏 운동(WOD)을 기록하고 트래킹하는 피트니스 앱. iOS/Android 동시 지원.',
    tags: ['React Native', 'Expo', 'Supabase', 'iOS', 'Android'],
    link: 'https://apps.apple.com/app/id6758967326',
    features: ['운동 기록 & 통계', '다크모드 UI', '실시간 동기화'],
    appStore: 'https://apps.apple.com/app/id6758967326',
    playStore: 'https://play.google.com/store/apps/details?id=com.wodmate.app',
  },
  {
    title: 'MyNurse',
    subtitle: '간호사를 위한 업무 도우미',
    category: '모바일 앱',
    image: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=800&h=450&fit=crop',
    overlay: 'from-rose-900/80 to-rose-800/40',
    description: '간호사의 업무 효율을 높여주는 똑똑한 도우미 앱. iOS/Android 지원, 다국어 대응.',
    tags: ['React Native', 'iOS', 'Android', '다국어', 'Healthcare'],
    link: 'https://apps.apple.com/app/id6759218620',
    features: ['업무 스케줄 관리', 'Push 알림', '다국어 지원'],
    appStore: 'https://apps.apple.com/app/id6759218620',
    playStore: 'https://play.google.com/store/apps/details?id=com.nursenote.app',
  },
  {
    title: '온도 (ONDO)',
    subtitle: '감성 카페 브랜드 사이트 (예시)',
    category: '랜딩페이지',
    image: 'https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=800&h=450&fit=crop',
    overlay: 'from-amber-900/80 to-amber-800/40',
    description: '따뜻한 감성의 카페 브랜드 사이트. 메뉴, 갤러리, 위치 안내까지 원페이지로 구성.',
    tags: ['Astro', 'Tailwind CSS', '반응형', '원페이지'],
    link: '/demo/cafe',
    features: ['탭 메뉴 시스템', '갤러리 레이아웃', '매장 안내'],
  },
  {
    title: 'Workfolio',
    subtitle: '외주 개발업체 사이트',
    category: '기업 홈페이지',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=450&fit=crop',
    overlay: 'from-indigo-900/80 to-indigo-800/40',
    description: '지금 보고 계신 이 사이트. 제작부터 관리까지, Workfolio의 서비스를 소개합니다.',
    tags: ['Astro', 'Cloudflare Pages', 'D1', 'Tailwind CSS'],
    link: 'https://workfolio.life',
    features: ['구독형 요금제', '상담 폼 & 관리자', 'SEO 최적화'],
  },
];
---

<section id="portfolio" class="py-24 sm:py-32 border-t border-surface-border">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-accent-light tracking-wider font-mono">// portfolio</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-white">
        이런 프로젝트를 만듭니다
      </h2>
      <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
        실제 운영 중인 서비스들입니다. 클릭하면 확인할 수 있습니다.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div
          class="group rounded-xl border border-surface-border bg-surface-light/20 overflow-hidden hover:border-accent/30 hover:shadow-xl hover:shadow-accent-glow/10 transition-all duration-300 cursor-pointer portfolio-card"
          data-link={project.link}
        >
          <!-- Preview Image -->
          <div class="relative aspect-[16/9] overflow-hidden">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class={`absolute inset-0 bg-gradient-to-t ${project.overlay}`}></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
              <p class="text-3xl sm:text-4xl font-extrabold text-white drop-shadow-lg mb-1">{project.title}</p>
              <p class="text-sm text-white/60 tracking-wide">{project.subtitle}</p>
            </div>
            <div class="absolute top-4 right-4 flex items-center gap-1.5 rounded-full bg-black/40 backdrop-blur-sm px-3 py-1.5 text-xs text-white/70 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
              방문하기
            </div>
            <div class="absolute top-4 left-4">
              <span class="rounded-full bg-black/40 backdrop-blur-sm px-3 py-1 text-xs font-medium text-white/80">
                {project.category}
              </span>
            </div>
          </div>

          <!-- Info -->
          <div class="p-6">
            <p class="text-sm text-muted leading-relaxed mb-4">{project.description}</p>

            <div class="flex flex-wrap gap-x-4 gap-y-1 mb-4">
              {project.features.map((f) => (
                <span class="flex items-center gap-1.5 text-xs text-muted/70">
                  <span class="w-1 h-1 rounded-full bg-accent-light/50"></span>
                  {f}
                </span>
              ))}
            </div>

            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-md border border-surface-border bg-surface-light/30 px-2.5 py-0.5 text-xs text-muted">
                  {tag}
                </span>
              ))}
            </div>

            {(project.appStore || project.playStore) && (
              <div class="flex items-center gap-3 pt-4 mt-4 border-t border-surface-border">
                {project.appStore && (
                  <a href={project.appStore} target="_blank" rel="noopener noreferrer" class="store-link flex items-center gap-2 rounded-lg border border-surface-border bg-surface-light/30 px-3 py-2 text-xs text-muted hover:border-accent/40 hover:text-white transition-all">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                    App Store
                  </a>
                )}
                {project.playStore && (
                  <a href={project.playStore} target="_blank" rel="noopener noreferrer" class="store-link flex items-center gap-2 rounded-lg border border-surface-border bg-surface-light/30 px-3 py-2 text-xs text-muted hover:border-accent/40 hover:text-white transition-all">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.807 1.626a1 1 0 010 1.732l-2.807 1.626L15.206 12l2.492-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
                    Google Play
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.portfolio-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      // 스토어 링크 클릭 시에는 카드 링크로 이동하지 않음
      if ((e.target as HTMLElement).closest('.store-link')) return;
      const link = (card as HTMLElement).dataset.link;
      if (link) window.open(link, '_blank');
    });
  });
</script>
