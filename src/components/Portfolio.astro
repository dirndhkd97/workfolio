---
const projects = [
  {
    title: '카페 브랜드 사이트',
    category: '랜딩페이지',
    gradient: 'from-violet-500/20 to-indigo-500/20',
    tags: ['디자인', '반응형', 'SEO'],
  },
  {
    title: '스타트업 홈페이지',
    category: '기업 홈페이지',
    gradient: 'from-cyan-500/20 to-blue-500/20',
    tags: ['기업', '다국어', '애니메이션'],
  },
  {
    title: '온라인 쇼핑몰',
    category: '쇼핑몰',
    gradient: 'from-rose-500/20 to-pink-500/20',
    tags: ['결제 연동', '재고 관리', '반응형'],
  },
  {
    title: '헬스케어 앱',
    category: '모바일 앱',
    gradient: 'from-emerald-500/20 to-teal-500/20',
    tags: ['iOS', 'Android', 'Push 알림'],
  },
];
---

<section id="portfolio" class="py-24 sm:py-32 border-t border-surface-border">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-accent-light tracking-wider font-mono">// portfolio</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-white">
        이런 프로젝트를 만듭니다
      </h2>
      <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
        다양한 업종의 경험을 바탕으로 최적의 솔루션을 제공합니다.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map((project) => (
        <div class="group rounded-xl border border-surface-border bg-surface-light/20 overflow-hidden hover:border-accent/20 transition-all duration-300">
          <div class={`aspect-[16/10] bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
            <div class="w-3/4 h-3/4 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm flex items-center justify-center">
              <span class="text-white/30 text-sm font-mono">preview</span>
            </div>
          </div>
          <div class="p-6">
            <span class="text-xs font-medium text-accent-light font-mono">{project.category}</span>
            <h3 class="mt-2 text-lg font-bold text-white">{project.title}</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-md border border-surface-border bg-surface-light/30 px-2.5 py-0.5 text-xs text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
