---
const projects = [
  {
    title: 'WODMate',
    subtitle: '크로스핏 운동 기록 앱',
    category: '모바일 앱',
    image: 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&h=450&fit=crop',
    overlay: 'from-teal-900/80 to-teal-800/40',
    accentColor: 'text-teal-400',
    description: '크로스핏 운동(WOD)을 기록하고 트래킹하는 피트니스 앱. iOS/Android 동시 지원.',
    tags: ['React Native', 'Expo', 'Supabase', 'iOS', 'Android'],
    link: 'https://wodmate.heewon.app',
    linkLabel: '앱 다운로드',
    features: ['운동 기록 & 통계', '다크모드 UI', '실시간 동기화'],
  },
  {
    title: 'MyNurse',
    subtitle: '간호사를 위한 업무 도우미',
    category: '모바일 앱',
    image: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=800&h=450&fit=crop',
    overlay: 'from-rose-900/80 to-rose-800/40',
    accentColor: 'text-rose-400',
    description: '간호사의 업무 효율을 높여주는 똑똑한 도우미 앱. iOS/Android 지원, 다국어 대응.',
    tags: ['React Native', 'iOS', 'Android', '다국어', 'Healthcare'],
    link: 'https://mynurse.heewon.app/app',
    linkLabel: '앱 다운로드',
    features: ['업무 스케줄 관리', 'Push 알림', '다국어 지원'],
  },
  {
    title: '온도 (ONDO)',
    subtitle: '감성 카페 브랜드 사이트',
    category: '랜딩페이지',
    image: 'https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=800&h=450&fit=crop',
    overlay: 'from-amber-900/80 to-amber-800/40',
    accentColor: 'text-amber-400',
    description: '따뜻한 감성의 카페 브랜드 사이트. 메뉴, 갤러리, 위치 안내까지 원페이지로 구성.',
    tags: ['Astro', 'Tailwind CSS', '반응형', '원페이지'],
    link: '/demo/cafe',
    linkLabel: '사이트 방문',
    features: ['탭 메뉴 시스템', '갤러리 레이아웃', '매장 안내'],
  },
  {
    title: 'Workfolio',
    subtitle: '외주 개발업체 사이트',
    category: '기업 홈페이지',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=450&fit=crop',
    overlay: 'from-indigo-900/80 to-indigo-800/40',
    accentColor: 'text-indigo-400',
    description: '지금 보고 계신 이 사이트. 제작부터 관리까지, Workfolio의 서비스를 소개합니다.',
    tags: ['Astro', 'Cloudflare Pages', 'D1', 'Tailwind CSS'],
    link: 'https://workfolio.life',
    linkLabel: '사이트 방문',
    features: ['구독형 요금제', '상담 폼 & 관리자', 'SEO 최적화'],
  },
];
---

<section id="portfolio" class="py-24 sm:py-32 border-t border-surface-border">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-accent-light tracking-wider font-mono">// portfolio</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-white">
        이런 프로젝트를 만듭니다
      </h2>
      <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
        실제 운영 중인 서비스들입니다. 클릭하면 확인할 수 있습니다.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group block rounded-xl border border-surface-border bg-surface-light/20 overflow-hidden hover:border-accent/30 hover:shadow-xl hover:shadow-accent-glow/10 transition-all duration-300"
        >
          <!-- Preview Image -->
          <div class="relative aspect-[16/9] overflow-hidden">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class={`absolute inset-0 bg-gradient-to-t ${project.overlay}`}></div>
            <!-- Title on image -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
              <p class={`text-3xl sm:text-4xl font-extrabold text-white drop-shadow-lg mb-1`}>{project.title}</p>
              <p class="text-sm text-white/60 tracking-wide">{project.subtitle}</p>
            </div>
            <!-- Badge -->
            <div class="absolute top-4 right-4 flex items-center gap-1.5 rounded-full bg-black/40 backdrop-blur-sm px-3 py-1.5 text-xs text-white/70 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
              {project.linkLabel}
            </div>
            <!-- Category badge -->
            <div class="absolute top-4 left-4">
              <span class="rounded-full bg-black/40 backdrop-blur-sm px-3 py-1 text-xs font-medium text-white/80">
                {project.category}
              </span>
            </div>
          </div>

          <!-- Info -->
          <div class="p-6">
            <p class="text-sm text-muted leading-relaxed mb-4">{project.description}</p>

            <div class="flex flex-wrap gap-x-4 gap-y-1 mb-4">
              {project.features.map((f) => (
                <span class="flex items-center gap-1.5 text-xs text-muted/70">
                  <span class="w-1 h-1 rounded-full bg-accent-light/50"></span>
                  {f}
                </span>
              ))}
            </div>

            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-md border border-surface-border bg-surface-light/30 px-2.5 py-0.5 text-xs text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
