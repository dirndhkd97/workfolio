---
const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>`,
    title: '웹사이트 제작',
    description: '랜딩페이지, 기업 홈페이지, 쇼핑몰 등 비즈니스에 최적화된 웹사이트를 제작합니다.',
    items: ['랜딩페이지', '기업 홈페이지', '쇼핑몰 / 예약 사이트', '관리자 대시보드'],
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`,
    title: '앱 개발',
    description: 'iOS · Android 크로스 플랫폼 앱을 하나의 코드베이스로 효율적으로 개발합니다.',
    items: ['iOS / Android 동시 출시', 'MVP 빠른 검증', '기존 앱 리뉴얼', 'Push 알림 · 결제 연동'],
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>`,
    title: '바이브코딩 유지보수',
    badge: 'NEW',
    description: 'AI로 만든 프로젝트, 관리가 막막하신가요? 코드 분석부터 안정화, 기능 추가까지 맡겨주세요.',
    items: ['코드 분석 · 리팩토링', '버그 수정 · 안정화', '기능 추가 · 고도화', '서버 · 배포 환경 세팅'],
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>`,
    title: '구독형 관리 서비스',
    description: '만들고 방치되는 사이트는 이제 그만. 구독 하나로 호스팅, 수정, 보안을 한번에.',
    items: ['호스팅 · 도메인 관리', '콘텐츠 수정 · SEO', '보안 업데이트', '장애 대응 · 모니터링'],
  },
];
---

<section id="services" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-accent-light tracking-wider font-mono">// services</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-white">
        무엇을 도와드릴까요?
      </h2>
      <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
        제작부터 유지보수까지, 기술의 모든 과정을 함께합니다.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {services.map((service) => (
        <div class="group relative rounded-xl border border-surface-border bg-surface-light/30 p-8 hover:border-accent/30 hover:bg-surface-light/60 transition-all duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-accent/10 text-accent-light">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-lg font-bold text-white">{service.title}</h3>
            {service.badge && (
              <span class="rounded-md bg-accent/20 px-2 py-0.5 text-xs font-bold text-accent-light">
                {service.badge}
              </span>
            )}
          </div>
          <p class="text-muted text-sm mb-6 leading-relaxed">{service.description}</p>
          <ul class="space-y-2">
            {service.items.map((item) => (
              <li class="flex items-center gap-2 text-sm text-muted">
                <span class="w-1 h-1 rounded-full bg-accent-light shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
