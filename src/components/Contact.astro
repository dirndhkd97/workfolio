<section id="contact" class="py-24 sm:py-32 border-t border-surface-border relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative mx-auto max-w-3xl px-6">
    <div class="text-center mb-12">
      <span class="text-sm font-medium text-accent-light tracking-wider font-mono">// contact</span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-white">
        프로젝트를 시작해볼까요?
      </h2>
      <p class="mt-4 text-lg text-muted">
        무료 상담을 통해 견적과 일정을 안내해 드립니다.
      </p>
    </div>

    <form id="contact-form" class="rounded-xl border border-surface-border bg-surface-light/30 p-8 sm:p-10">
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm font-medium text-muted mb-2">이름 / 회사명</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full rounded-lg border border-surface-border bg-surface/50 px-4 py-3 text-sm text-white placeholder-muted/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
            placeholder="홍길동 / 주식회사 OO"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-muted mb-2">연락처</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            class="w-full rounded-lg border border-surface-border bg-surface/50 px-4 py-3 text-sm text-white placeholder-muted/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
            placeholder="010-0000-0000"
          />
        </div>
      </div>

      <div class="mt-6">
        <label for="email" class="block text-sm font-medium text-muted mb-2">이메일</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full rounded-lg border border-surface-border bg-surface/50 px-4 py-3 text-sm text-white placeholder-muted/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
          placeholder="example@email.com"
        />
      </div>

      <!-- Custom Select: 프로젝트 유형 -->
      <div class="mt-6">
        <label class="block text-sm font-medium text-muted mb-2">프로젝트 유형</label>
        <div class="custom-select" data-name="type">
          <button type="button" class="select-trigger w-full flex items-center justify-between rounded-lg border border-surface-border bg-surface/50 px-4 py-3 text-sm text-left transition-all focus:border-accent focus:ring-1 focus:ring-accent outline-none">
            <span class="select-value text-muted/50">선택해주세요</span>
            <svg class="select-arrow w-4 h-4 text-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="select-dropdown hidden absolute z-20 mt-2 w-full rounded-xl border border-surface-border bg-surface-light shadow-2xl shadow-black/50 overflow-hidden">
            <div class="p-1.5">
              <div class="px-3 py-1.5 text-xs font-semibold text-muted/60 uppercase tracking-wider">웹</div>
              <button type="button" class="select-option w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="landing">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-500/10 text-violet-400 shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </span>
                <div>
                  <div class="font-medium">랜딩페이지</div>
                  <div class="text-xs text-muted/50">소개 · 프로모션 · 이벤트</div>
                </div>
              </button>
              <button type="button" class="select-option w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="corporate">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-blue-500/10 text-blue-400 shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </span>
                <div>
                  <div class="font-medium">기업 홈페이지</div>
                  <div class="text-xs text-muted/50">회사 소개 · 채용 · IR</div>
                </div>
              </button>
              <button type="button" class="select-option w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="shopping">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-pink-500/10 text-pink-400 shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                </span>
                <div>
                  <div class="font-medium">쇼핑몰</div>
                  <div class="text-xs text-muted/50">결제 · 재고 관리 · 배송</div>
                </div>
              </button>

              <div class="my-1.5 border-t border-surface-border"></div>
              <div class="px-3 py-1.5 text-xs font-semibold text-muted/60 uppercase tracking-wider">앱</div>
              <button type="button" class="select-option w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="app">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-cyan-500/10 text-cyan-400 shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                </span>
                <div>
                  <div class="font-medium">모바일 앱</div>
                  <div class="text-xs text-muted/50">iOS · Android 크로스 플랫폼</div>
                </div>
              </button>

              <div class="my-1.5 border-t border-surface-border"></div>
              <div class="px-3 py-1.5 text-xs font-semibold text-muted/60 uppercase tracking-wider">기타</div>
              <button type="button" class="select-option w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="vibe">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-amber-500/10 text-amber-400 shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                </span>
                <div>
                  <div class="font-medium">바이브코딩 유지보수</div>
                  <div class="text-xs text-muted/50">AI로 만든 프로젝트 안정화 · 관리</div>
                </div>
              </button>
              <button type="button" class="select-option w-full flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="other">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-500/10 text-gray-400 shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                </span>
                <div>
                  <div class="font-medium">기타 / 상담 후 결정</div>
                  <div class="text-xs text-muted/50">어떤 것이 필요한지 함께 고민해요</div>
                </div>
              </button>
            </div>
          </div>
          <input type="hidden" name="type" />
        </div>
      </div>

      <!-- Custom Select: 예산 범위 -->
      <div class="mt-6">
        <label class="block text-sm font-medium text-muted mb-2">예산 범위</label>
        <div class="custom-select" data-name="budget">
          <button type="button" class="select-trigger w-full flex items-center justify-between rounded-lg border border-surface-border bg-surface/50 px-4 py-3 text-sm text-left transition-all focus:border-accent focus:ring-1 focus:ring-accent outline-none">
            <span class="select-value text-muted/50">선택해주세요</span>
            <svg class="select-arrow w-4 h-4 text-muted transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="select-dropdown hidden absolute z-20 mt-2 w-full rounded-xl border border-surface-border bg-surface-light shadow-2xl shadow-black/50 overflow-hidden">
            <div class="p-1.5">
              <button type="button" class="select-option w-full flex items-center justify-between rounded-lg px-4 py-3 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="50">
                <span>50만원 이하</span>
                <span class="text-xs text-muted/40">심플 랜딩페이지</span>
              </button>
              <button type="button" class="select-option w-full flex items-center justify-between rounded-lg px-4 py-3 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="50-100">
                <span>50 ~ 100만원</span>
                <span class="text-xs text-muted/40">홈페이지 · 소규모 쇼핑몰</span>
              </button>
              <button type="button" class="select-option w-full flex items-center justify-between rounded-lg px-4 py-3 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="100-300">
                <span>100 ~ 300만원</span>
                <span class="text-xs text-muted/40">기능형 사이트 · MVP 앱</span>
              </button>
              <button type="button" class="select-option w-full flex items-center justify-between rounded-lg px-4 py-3 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="300-500">
                <span>300 ~ 500만원</span>
                <span class="text-xs text-muted/40">앱 · 복합 플랫폼</span>
              </button>
              <button type="button" class="select-option w-full flex items-center justify-between rounded-lg px-4 py-3 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="500+">
                <span>500만원 이상</span>
                <span class="text-xs text-muted/40">대규모 프로젝트</span>
              </button>
              <button type="button" class="select-option w-full flex items-center justify-between rounded-lg px-4 py-3 text-sm text-muted hover:bg-accent/10 hover:text-white transition-all text-left" data-value="consult">
                <span>상담 후 결정</span>
                <span class="text-xs text-muted/40">예산 협의 가능</span>
              </button>
            </div>
          </div>
          <input type="hidden" name="budget" />
        </div>
      </div>

      <div class="mt-6">
        <label for="message" class="block text-sm font-medium text-muted mb-2">프로젝트 설명</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          class="w-full rounded-lg border border-surface-border bg-surface/50 px-4 py-3 text-sm text-white placeholder-muted/50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all resize-none"
          placeholder="프로젝트에 대해 간단히 설명해주세요. 참고 사이트나 앱이 있으면 알려주세요."
        ></textarea>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="mt-8 w-full rounded-lg bg-accent py-4 text-base font-semibold text-white hover:bg-accent-light shadow-lg shadow-accent-glow transition-all"
      >
        무료 상담 신청하기
      </button>
    </form>

    <!-- 제출 완료 화면 -->
    <div id="contact-success" class="hidden rounded-xl border border-surface-border bg-surface-light/30 p-10 sm:p-14 text-center">
      <div class="mx-auto mb-6 w-16 h-16 rounded-full bg-green-500/10 flex items-center justify-center">
        <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-white mb-3">상담 신청이 접수되었습니다</h3>
      <p class="text-muted leading-relaxed mb-2">
        빠른 시일 내에 연락드리겠습니다.
      </p>
      <p class="text-muted text-sm mb-8">
        급한 문의는 <a href="mailto:dirndhkd97@gmail.com" class="text-accent-light hover:underline">dirndhkd97@gmail.com</a>으로 메일 주세요.
      </p>

      <div id="submitted-summary" class="rounded-lg border border-surface-border bg-surface/50 p-6 text-left mb-8">
        <p class="text-xs font-semibold text-accent-light font-mono mb-4">// 신청 내역</p>
        <dl class="space-y-3 text-sm">
          <div class="flex gap-3">
            <dt class="text-muted/60 w-20 shrink-0">이름</dt>
            <dd id="sum-name" class="text-white"></dd>
          </div>
          <div class="flex gap-3">
            <dt class="text-muted/60 w-20 shrink-0">연락처</dt>
            <dd id="sum-phone" class="text-white"></dd>
          </div>
          <div class="flex gap-3">
            <dt class="text-muted/60 w-20 shrink-0">이메일</dt>
            <dd id="sum-email" class="text-white"></dd>
          </div>
          <div class="flex gap-3">
            <dt class="text-muted/60 w-20 shrink-0">유형</dt>
            <dd id="sum-type" class="text-white"></dd>
          </div>
          <div class="flex gap-3">
            <dt class="text-muted/60 w-20 shrink-0">예산</dt>
            <dd id="sum-budget" class="text-white"></dd>
          </div>
          <div id="sum-message-row" class="flex gap-3">
            <dt class="text-muted/60 w-20 shrink-0">설명</dt>
            <dd id="sum-message" class="text-white"></dd>
          </div>
        </dl>
      </div>

      <button
        id="reset-form-btn"
        class="inline-flex items-center gap-2 rounded-lg border border-surface-border px-6 py-3 text-sm font-medium text-muted hover:border-accent/50 hover:text-white transition-all"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
        새 상담 신청하기
      </button>
    </div>
  </div>
</section>

<style>
  .custom-select {
    position: relative;
  }
  .custom-select.open .select-arrow {
    transform: rotate(180deg);
  }
  .custom-select.open .select-trigger {
    border-color: #6366f1;
    box-shadow: 0 0 0 1px #6366f1;
  }
</style>

<script>
  // Custom select logic
  document.querySelectorAll('.custom-select').forEach((select) => {
    const trigger = select.querySelector('.select-trigger') as HTMLButtonElement;
    const dropdown = select.querySelector('.select-dropdown') as HTMLDivElement;
    const valueDisplay = select.querySelector('.select-value') as HTMLSpanElement;
    const hiddenInput = select.querySelector('input[type="hidden"]') as HTMLInputElement;
    const options = select.querySelectorAll('.select-option');

    trigger?.addEventListener('click', () => {
      // Close all other dropdowns first
      document.querySelectorAll('.custom-select').forEach((s) => {
        if (s !== select) {
          s.classList.remove('open');
          s.querySelector('.select-dropdown')?.classList.add('hidden');
        }
      });
      select.classList.toggle('open');
      dropdown?.classList.toggle('hidden');
    });

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const value = (option as HTMLElement).dataset.value || '';
        const label = option.querySelector('.font-medium')?.textContent
          || option.querySelector('span')?.textContent
          || '';
        hiddenInput.value = value;
        valueDisplay.textContent = label;
        valueDisplay.classList.remove('text-muted/50');
        valueDisplay.classList.add('text-white');
        select.classList.remove('open');
        dropdown?.classList.add('hidden');
      });
    });
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.custom-select').forEach((select) => {
      if (!select.contains(e.target as Node)) {
        select.classList.remove('open');
        select.querySelector('.select-dropdown')?.classList.add('hidden');
      }
    });
  });

  // Label maps for display
  const typeLabels: Record<string, string> = {
    landing: '랜딩페이지',
    corporate: '기업 홈페이지',
    shopping: '쇼핑몰',
    app: '모바일 앱',
    vibe: '바이브코딩 유지보수',
    other: '기타 / 상담 후 결정',
  };
  const budgetLabels: Record<string, string> = {
    '50': '50만원 이하',
    '50-100': '50 ~ 100만원',
    '100-300': '100 ~ 300만원',
    '300-500': '300 ~ 500만원',
    '500+': '500만원 이상',
    consult: '상담 후 결정',
  };

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('contact-success') as HTMLDivElement;
  const resetBtn = document.getElementById('reset-form-btn') as HTMLButtonElement;

  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form)) as Record<string, string>;

    // 버튼 로딩 상태
    submitBtn.disabled = true;
    submitBtn.textContent = '전송 중...';

    try {
      // API 호출
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error('API error');
    } catch {
      // API 실패해도 확인 화면은 보여줌 (오프라인 등)
      console.warn('API call failed, but showing success screen');
    }

    submitBtn.disabled = false;
    submitBtn.textContent = '무료 상담 신청하기';

    // Fill summary
    (document.getElementById('sum-name') as HTMLElement).textContent = data.name || '-';
    (document.getElementById('sum-phone') as HTMLElement).textContent = data.phone || '-';
    (document.getElementById('sum-email') as HTMLElement).textContent = data.email || '-';
    (document.getElementById('sum-type') as HTMLElement).textContent = typeLabels[data.type] || '미선택';
    (document.getElementById('sum-budget') as HTMLElement).textContent = budgetLabels[data.budget] || '미선택';

    const msgRow = document.getElementById('sum-message-row') as HTMLElement;
    const msgEl = document.getElementById('sum-message') as HTMLElement;
    if (data.message?.trim()) {
      msgEl.textContent = data.message;
      msgRow.classList.remove('hidden');
    } else {
      msgRow.classList.add('hidden');
    }

    // Show success, hide form
    form.classList.add('hidden');
    successEl.classList.remove('hidden');
    successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Reset back to form
  resetBtn?.addEventListener('click', () => {
    form.reset();
    form.querySelectorAll('.select-value').forEach((v) => {
      v.textContent = '선택해주세요';
      v.classList.add('text-muted/50');
      v.classList.remove('text-white');
    });
    form.querySelectorAll('input[type="hidden"]').forEach((input) => {
      (input as HTMLInputElement).value = '';
    });
    successEl.classList.add('hidden');
    form.classList.remove('hidden');
    form.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>
